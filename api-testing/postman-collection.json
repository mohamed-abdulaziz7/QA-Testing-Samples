              "});\r",
              "\r",
              "pm.test(\"Error message is correct\", function () {\r",
              "    pm.expect(responseJson.error).to.eql(\"Invalid tracking number!\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains status field\", function () {\r",
              "    pm.expect(responseJson).to.have.property(\"status\");\r",
              "});\r",
              "\r",
              "pm.test('Status value is \"Not Found.\"', function () {\r",
              "    pm.expect(responseJson.status).to.eql(\"Not Found.\");\r",
              "});\r",
              ""
