  "item": [
    {
      "name": "Valid Tracking Number",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//  tracking number = 6636234, 7234258, 9442984, 1094442 \r",
              "pm.collectionVariables.set(\"trackingNumber\", \"7234258\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 100 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(100);\r",
              "});\r",
              "\r",
              "pm.test(\"Response body is JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "const responseJson = pm.response.json();\r",
              "\r",
              "pm.test('Provider value is \"Bosta\"', function () {\r",
              "    pm.expect(responseJson.provider).to.eql(\"Bosta\");\r",
              "});\r",
              "\r",
              "pm.test(\"TrackingNumber exists in response\", function () {\r",
              "    pm.expect(responseJson).to.have.property(\"TrackingNumber\");\r",
              "});\r",
              "\r",
              "pm.test(\"TrackingNumber matches requested tracking number\", function () {\r",
              "    pm.expect(responseJson.TrackingNumber.toString()).to.eql(pm.variables.get(\"trackingNumber\").toString());\r",
              "});\r",
              "\r",
              "pm.test(\"Successful GET request\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200]);\r",
              "});\r",
              "\r",
              "pm.test(\"CreateDate exists in response\", function () {\r",
              "    pm.expect(responseJson).to.have.property(\"CreateDate\");\r",
              "});\r",
              "\r",
              "pm.test(\"SupportPhoneNumbers exists in response\", function () {\r",
              "    pm.expect(responseJson).to.have.property(\"SupportPhoneNumbers\");\r",
              "});\r",
              "\r",
              "pm.test(\"SupportPhoneNumbers is an array\", function () {\r",
              "    pm.expect(responseJson.SupportPhoneNumbers).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"TrackingURL exists in response\", function () {\r",
              "    pm.expect(responseJson).to.have.property(\"TrackingURL\");\r",
              "});\r",
              "\r",
              "pm.test(\"TrackingURL\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"track_num=7234258\");\r",
              "});\r",
              "\r",
              "// Header Validation\r",
              "pm.test(\"Ensure that the content-type exists in the response\", function(){\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "});\r",
              "\r",
              "pm.test(\"Content-Type is application/json\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "X-Requested-By",
            "value": "Landmark",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{URL}}/shipments/track/{{trackingNumber}}",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "shipments",
            "track",
            "{{trackingNumber}}"
          ]
        }
      },
      "response": []
    },
